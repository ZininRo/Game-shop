        User user = (User) SecurityContextHolder
                .getContext()
                .getAuthentication()
                .getPrincipal();

        Client client = clientRepository
                .findByUserId(user.getId())
                .orElseThrow();

        List<Order> orders = orderRepository
                .findByClientAndStatusNotOrderByOrderDateDesc(
