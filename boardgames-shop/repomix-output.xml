package boardgames_shop.repository;

import boardgames_shop.entity.Client;
import boardgames_shop.entity.Employee;
import boardgames_shop.entity.Order;
import boardgames_shop.entity.OrderStatus;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;

public interface OrderRepository extends JpaRepository<Order, Long> {

    @Query("""
        SELECT DISTINCT o
        FROM Order o
        WHERE o.client = (
            SELECT c FROM Client c WHERE c = :client
        )
        """)
    List<Order> findByClient(@Param("client") Client client);
//    List<Order> findByClient(Client client);
    Optional<Order> findByClientAndStatus(Client client, OrderStatus status);
    List<Order> findByStatus(OrderStatus status);
//    List<Order> findByClientAndStatusNot(Client client, OrderStatus status);
    List<Order> findByClientAndStatusNotOrderByOrderDateDesc(Client client, OrderStatus status);
    List<Order> findByEmployee(Employee employee);
    List<Order> findByStatusAndEmployeeIsNullOrderByIdAsc(OrderStatus status);
    List<Order> findByEmployeeOrderByIdAsc(Employee employee);
    List<Order> findByStatusNot(OrderStatus status);
    List<Order> findByStatusNotOrderByIdAsc(OrderStatus status);

    // ===== Reports =====

    /**
     * Все завершённые заказы за диапазон дат (orderDate >= from AND orderDate < to)
     * Используется для: график по месяцу, статистика за период, сравнение месяцев
     */
    @Query("SELECT o FROM Order o WHERE o.status = 'COMPLETED' " +
            "AND o.orderDate >= :from AND o.orderDate < :to " +
            "ORDER BY o.orderDate ASC")
    List<Order> findCompletedBetween(
            @Param("from") LocalDateTime from,
            @Param("to")   LocalDateTime to
    );

    // ===== Фильтр 1: Последние N заказов =====
    // Подзапрос выбирает ID последних N заказов (по дате, исключая NOT_CREATED),
    // внешний запрос достаёт полные объекты с сортировкой.
    // Операнды: подзапрос, ORDER BY, LIMIT (через @Query + нативный LIMIT через JPQL rownum / subquery)
    @Query("""
        SELECT DISTINCT o
        FROM Order o
        WHERE o.status <> boardgames_shop.entity.OrderStatus.NOT_CREATED
          AND o.id IN (
              SELECT o2.id
              FROM Order o2
              WHERE o2.status <> boardgames_shop.entity.OrderStatus.NOT_CREATED
              ORDER BY o2.orderDate DESC
              LIMIT :limit
          )
        ORDER BY o.orderDate DESC
        """)
    List<Order> findLastNOrders(@Param("limit") int limit);

    // ===== Фильтр 2: Заказы с несколькими позициями =====
    // Подзапрос с DISTINCT: выбирает ID заказов, у которых количество
    // уникальных игр (DISTINCT game_id) больше одной.
    // Операнды: подзапрос, DISTINCT, HAVING, ORDER BY.
    @Query("""
        SELECT o
        FROM Order o
        WHERE o.status <> boardgames_shop.entity.OrderStatus.NOT_CREATED
          AND o.id IN (
              SELECT DISTINCT oi.order.id
              FROM OrderItem oi
              GROUP BY oi.order.id
              HAVING COUNT(DISTINCT oi.game.id) > 1
          )
        ORDER BY o.id ASC
        """)
    List<Order> findOrdersWithMultipleItems();

}
