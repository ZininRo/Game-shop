                    order.getItems()
                            .stream()
                            .map(i -> i.getPriceAtPurchase()
                                    .multiply(BigDecimal.valueOf(i.getQuantity())))
                            .reduce(BigDecimal.ZERO, BigDecimal::add)
            );

