package boardgames_shop.service;

import boardgames_shop.dto.admin.*;
import boardgames_shop.entity.*;
import boardgames_shop.repository.*;
import jakarta.transaction.Transactional;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;

import java.util.ArrayList;
import java.util.Comparator;
import java.util.List;
import java.util.Arrays;

@Service
@Transactional
public class AdminService {

    private final EmployeeRepository employeeRepository;
    private final ClientRepository clientRepository;
    private final GameRepository gameRepository;
    private final OrderRepository orderRepository;
    private final RoleRepository roleRepository;
    private final UserRepository userRepository;
    private final PasswordEncoder passwordEncoder;

    public AdminService(
            EmployeeRepository employeeRepository,
            ClientRepository clientRepository,
            GameRepository gameRepository,
            OrderRepository orderRepository,
            RoleRepository roleRepository,
            UserRepository userRepository,
            PasswordEncoder passwordEncoder
    ) {
        this.employeeRepository = employeeRepository;
        this.clientRepository = clientRepository;
        this.gameRepository = gameRepository;
        this.orderRepository = orderRepository;
        this.roleRepository = roleRepository;
        this.userRepository = userRepository;
        this.passwordEncoder = passwordEncoder;
    }

    // Сотрудники

    public List<EmployeeResponse> getEmployees() {

        List<Employee> employees = employeeRepository.findAllActiveEmployees();
        List<OrderStatus> activeStatuses = Arrays.asList(
                OrderStatus.CREATED,
                OrderStatus.IN_TRANSIT,
                OrderStatus.PICKUP_POINT
        );

        List<EmployeeResponse> list = new ArrayList<>();

        for (Employee e : employees) {

            EmployeeResponse dto = new EmployeeResponse();

            dto.setId(e.getId());
            dto.setName(e.getFullName());
            dto.setEmail(e.getUser().getEmail());
            dto.setPhone(e.getPhone());
            dto.setPosition(e.getPosition());
            dto.setRole(e.getUser().getRole().getName());

            // Считаем активные заказы: всё кроме COMPLETED и CANCELLED
            long activeCount = orderRepository
                    .findAll()
                    .stream()
                    .filter(o -> o.getEmployee() != null
                            && o.getEmployee().getId().equals(e.getId())
                            && activeStatuses.contains(o.getStatus()))
                    .count();

            dto.setActiveOrdersCount((int) activeCount);
            list.add(dto);
        }

        return list;
    }

    public void createEmployee(CreateEmployeeRequest request) {

        Role role = roleRepository
                .findByName(request.getRole())
                .orElseThrow(() -> new RuntimeException("Role not found: " + request.getRole()));

        User user = new User();
        user.setEmail(request.getEmail());
        // Кодируем пароль перед сохранением
        user.setPassword(passwordEncoder.encode(request.getPassword()));
        user.setRole(role);

        userRepository.save(user);

        Employee employee = new Employee();
        employee.setFullName(request.getName());
        employee.setPhone(request.getPhone());
        employee.setPosition(request.getPosition());
        employee.setUser(user);

        employeeRepository.save(employee);
    }

    public void deleteEmployee(Long employeeId) {
        // 1. Найти сотрудника-заглушку (например, id = 1)
        Employee placeholderEmployee = employeeRepository.findById(4L)
                .orElseThrow(() -> new RuntimeException("Сотрудник-заглушка с id=1 не найден"));

        // 2. Найти удаляемого сотрудника
        Employee employeeToDelete = employeeRepository.findById(employeeId)
                .orElseThrow(() -> new RuntimeException("Сотрудник с id=" + employeeId + " не найден"));

        // 3. Переназначить все заказы, закреплённые за этим сотрудником, на заглушку
        List<Order> orders = orderRepository.findByEmployee(employeeToDelete);
        for (Order order : orders) {
            order.setEmployee(placeholderEmployee);
        }
        if (!orders.isEmpty()) {
            orderRepository.saveAll(orders);
        }

        // 4. Получить связанного пользователя
        User userToDelete = employeeToDelete.getUser();

        // 5. Если пользователь существует – удаляем его
        if (userToDelete != null) {
            // Сначала отвязываем сотрудника от пользователя
            employeeToDelete.setUser(null);
            employeeRepository.save(employeeToDelete);
            // Удаляем пользователя
            userRepository.delete(userToDelete);
        }

        // 6. Удаляем сотрудника
        employeeRepository.delete(employeeToDelete);
    }

    // Клиенты
    public List<ClientResponse> getClients() {

        List<Client> clients = clientRepository.findAllActiveClients();
        List<ClientResponse> list = new ArrayList<>();

        for (Client c : clients) {

            ClientResponse dto = new ClientResponse();

            dto.setId(c.getId());
            dto.setName(c.getFullName());
            dto.setEmail(c.getUser().getEmail());
            dto.setPhone(c.getPhone());
            dto.setBirthDate(c.getBirthDate());

            list.add(dto);
        }

        return list;
    }


    public void deleteClient(Long clientId) {
        // 1. Найти клиента-заглушку (id=5)
        Client placeholderClient = clientRepository.findById(5L)
                .orElseThrow(() -> new RuntimeException("Клиент-заглушка с id=5 не найден"));

        // 2. Найти удаляемого клиента
        Client clientToDelete = clientRepository.findById(clientId)
                .orElseThrow(() -> new RuntimeException("Клиент с id=" + clientId + " не найден"));

        // 3. Переназначить все заказы удаляемого клиента на заглушку
        List<Order> orders = orderRepository.findByClient(clientToDelete);
        for (Order order : orders) {
            order.setClient(placeholderClient);
        }
        if (!orders.isEmpty()) {
            orderRepository.saveAll(orders);
        }

        // 4. Получить связанного пользователя
        User userToDelete = clientToDelete.getUser();

        // 5. Если пользователь существует – удаляем его
        if (userToDelete != null) {
            // Сначала отвязываем клиента от пользователя, чтобы не нарушить FK при удалении пользователя
            clientToDelete.setUser(null);
            clientRepository.save(clientToDelete);
            // Удаляем пользователя
            userRepository.delete(userToDelete);
        }

        // 6. Удаляем клиента
        clientRepository.delete(clientToDelete);
    }

    // Игры

    public List<GameResponse> getGames() {
        List<Game> games = gameRepository.findAllByOrderByIdAsc();
        List<GameResponse> list = new ArrayList<>();
        for (Game g : games) {
            GameResponse dto = new GameResponse();
            dto.setId(g.getId());
            dto.setName(g.getName());
            dto.setPrice(g.getPrice());
            dto.setDescription(g.getDescription());
            dto.setActive(g.isActive());   // важно для интерфейса администратора
            list.add(dto);
        }
        return list;
    }

    public void deleteGame(Long id) {
        Game game = gameRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Игра не найдена"));
        game.setActive(false);
        gameRepository.save(game);
    }
    public void createGame(CreateGameRequest request) {
        Game game = new Game();
        game.setName(request.getName());
        game.setPrice(request.getPrice());
        game.setDescription(request.getDescription());
        game.setActive(true);   // явно
        gameRepository.save(game);
    }

    public void restoreGame(Long id) {
        Game game = gameRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Игра не найдена"));
        game.setActive(true);
        gameRepository.save(game);
    }

    public void updateGame(Long id, UpdateGameRequest request) {
        Game game = gameRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Игра не найдена"));
        if (request.getName() != null) game.setName(request.getName());
        if (request.getPrice() != null) game.setPrice(request.getPrice());
        if (request.getDescription() != null) game.setDescription(request.getDescription());
        if (request.getActive() != null) game.setActive(request.getActive());
        gameRepository.save(game);
    }


    // Заказы

    public List<AdminOrderResponse> getOrders() {
        List<Order> orders = orderRepository.findByStatusNotOrderByIdAsc(OrderStatus.NOT_CREATED);
        List<AdminOrderResponse> list = new ArrayList<>();

        for (Order o : orders) {
            AdminOrderResponse dto = new AdminOrderResponse();
            dto.setId(o.getId());

            // Извлекаем ФИО клиента
            dto.setClient(o.getClient() != null ? o.getClient().getFullName() : "Удаленный пользователь");

            // Извлекаем ФИО менеджера
            dto.setManager(o.getEmployee() != null ? o.getEmployee().getFullName() : null);

            dto.setStatus(o.getStatus().name());
            dto.setOrderDate(o.getOrderDate());
            dto.setDeliveryDate(o.getDeliveryDate());
            dto.setTotal(o.getTotalPrice());

            List<OrderItemDto> itemsList = new ArrayList<>();

            if (o.getItems() != null) {
                // Сортируем список OrderItem по id, как в примере с корзиной
                List<OrderItem> sortedItems = o.getItems().stream()
                        .sorted(Comparator.comparing(OrderItem::getId))
                        .toList();

                // Теперь перебираем уже отсортированный список
                for (OrderItem item : sortedItems) {
                    OrderItemDto itemDto = new OrderItemDto();
                    itemDto.setName(item.getGame().getName());
                    itemDto.setQuantity(item.getQuantity());
                    itemDto.setPrice(item.getPriceAtPurchase().intValueExact());

                    itemsList.add(itemDto);
                }
            }

            dto.setItems(itemsList);
            list.add(dto);
        }

        return list;
    }


    public void updateOrder(Long id, UpdateOrderAdminRequest request) {

        Order order = orderRepository.findById(id).orElseThrow();

        if (request.getManagerId() != null) {

            Employee employee =
                    employeeRepository
                            .findById(request.getManagerId())
                            .orElseThrow();

            order.setEmployee(employee);
        }

        order.setDeliveryDate(request.getDeliveryDate());
        order.setStatus(OrderStatus.valueOf(request.getStatus()));
        order.setTotalPrice(request.getTotal());

        orderRepository.save(order);
    }

    public void updateEmployee(
            Long id,
            UpdateEmployeeRequest request
    ) {

        Employee employee =
                employeeRepository.findById(id).orElseThrow();

        employee.setFullName(request.getName());
        employee.setPhone(request.getPhone());
        employee.setPosition(request.getPosition());

        Role role =
                roleRepository
                        .findByName(request.getRole())
                        .orElseThrow();

        employee.getUser().setRole(role);

        employeeRepository.save(employee);
    }

    public void updateClient(
            Long id,
            UpdateClientRequest request
    ) {

        Client client =
                clientRepository.findById(id).orElseThrow();

        client.setFullName(request.getName());
        client.setPhone(request.getPhone());
        client.setBirthDate(request.getBirthDate());

        clientRepository.save(client);
    }


    public List<AdminOrderResponse> getLastOrders(int limit) {
        List<Order> orders = orderRepository.findLastNOrders(limit);
        return mapOrdersToResponse(orders);
    }

    // ===== Фильтр: заказы с несколькими позициями =====

    public List<AdminOrderResponse> getOrdersWithMultipleItems() {
        List<Order> orders = orderRepository.findOrdersWithMultipleItems();
        return mapOrdersToResponse(orders);
    }

    // ===== Приватный маппер (вынести логику из getOrders()) =====
    // Заменить тело getOrders() на:
    //   return mapOrdersToResponse(orderRepository.findByStatusNotOrderByIdAsc(OrderStatus.NOT_CREATED));
    // И добавить этот метод:

    private List<AdminOrderResponse> mapOrdersToResponse(List<Order> orders) {
        List<AdminOrderResponse> list = new ArrayList<>();

        for (Order o : orders) {
            AdminOrderResponse dto = new AdminOrderResponse();
            dto.setId(o.getId());
            dto.setClient(o.getClient() != null ? o.getClient().getFullName() : "Удаленный пользователь");
            dto.setManager(o.getEmployee() != null ? o.getEmployee().getFullName() : null);
            dto.setStatus(o.getStatus().name());
            dto.setOrderDate(o.getOrderDate());
            dto.setDeliveryDate(o.getDeliveryDate());
            dto.setTotal(o.getTotalPrice());

            List<OrderItemDto> itemsList = new ArrayList<>();
            if (o.getItems() != null) {
                List<OrderItem> sortedItems = o.getItems().stream()
                        .sorted(Comparator.comparing(OrderItem::getId))
                        .toList();
                for (OrderItem item : sortedItems) {
                    OrderItemDto itemDto = new OrderItemDto();
                    itemDto.setName(item.getGame().getName());
                    itemDto.setQuantity(item.getQuantity());
                    itemDto.setPrice(item.getPriceAtPurchase().intValueExact());
                    itemsList.add(itemDto);
                }
            }
            dto.setItems(itemsList);
            list.add(dto);
        }
        return list;
    }

}
